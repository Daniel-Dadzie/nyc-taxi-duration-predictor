# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# ── Required ──────────────────────────────────────────────────────
# MLflow tracking server (Cloud Run, provided by Cloud team)
MLFLOW_TRACKING_URI=https://mlflow-server-662636572351.us-central1.run.app

# Path to training dataset (GCS path, provided by Cloud team)
DATA_PATH=gs://group-a1-mlflow-artifacts/data/train.csv

# ── Optional (defaults shown) ─────────────────────────────────────
MLFLOW_EXPERIMENT_NAME=project-a-group-a1
MODEL_REGISTRY_NAME=group-a1-model
